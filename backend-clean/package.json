{
  "name": "voltway-backend",
  "version": "1.0.0",
  "description": "Backend para aplicação VoltWay - Sistema de estações de carregamento elétrico",
  "main": "server.js",
  "scripts": {
    "start": "node server.refactored.js",
    "dev": "nodemon server.refactored.js",
    "migrate": "node migrations/migrate.js",
    "seed": "node migrations/seed.js",
    "test": "node test-deploy.js",
    "test:db": "node test-connection.js",
    "test:integration": "node tests/test-integration.js",
    "test:e2e": "node tests/test-ponta-a-ponta.js",
    "populate:stations": "node scripts/populate-google-stations.js",
    "view:db": "node scripts/view-database.js",
    "postinstall": "npm run migrate && npm run seed",
    "railway:deploy": "npm run migrate && npm run seed && npm start"
  },
  "keywords": [
    "voltway",
    "electric-vehicle",
    "charging-stations",
    "postgresql"
  ],
  "author": "VoltWay Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "axios": "^1.13.2",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
